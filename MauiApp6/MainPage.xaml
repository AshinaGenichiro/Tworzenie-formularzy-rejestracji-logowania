<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiApp6.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label
                Text="Zaloguj się"
                FontSize="32"
                HorizontalOptions="Center" />
            <Entry
                x:Name="emailEntry"
                Placeholder="E-mail"
                FontSize="18" 
                Keyboard="Email"
                TextChanged="checkIfLogged"/>
            <Entry
                x:Name="passwordEntry"
                Placeholder="Hasło"
                FontSize="18"
                IsPassword="True"
                TextChanged="checkIfLogged"/>
            <Button
                x:Name="loginButton"
                Text="Zaloguj się"
                FontSize="18"
                BackgroundColor="#007AFF"
                TextColor="White"
                IsVisible="False"
                Clicked="onSend"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
